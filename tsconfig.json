{
  "compilerOptions": {
    "target": "ES2020",

    "module": "CommonJS",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "allowJs": true,
    "checkJs": false,
    "declaration": false,

    "resolveJsonModule": true,
    "types": ["jest"]
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}